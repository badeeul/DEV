	measure 'Yield Ratio' =
			
			DIVIDE([Issued],[Submitted])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Measures (Not Time Period Specific)\Ratios
		lineageTag: 36acc15d-8fbb-4a53-a148-0c4c1c6e1b2b

	measure 'Data Last Date' =
			
			CALCULATE(
			    MAX(wc_carrier_placement_snapshot[policy_sub_dt]),
			    ALL(wc_carrier_placement_snapshot)
			)
		formatString: Short Date
		displayFolder: Date Helpers
		lineageTag: 208c2405-af0f-4dea-8548-aae7a3bc2813

	measure Implementation_WindowEnd = [Data Last Date]
		formatString: General Date
		displayFolder: Date Helpers
		lineageTag: cba6ab60-d724-4beb-9f67-b73c09a0b287

	measure Implementation_WindowStart =
			
			IF (
			    NOT [Has Selection],
			    BLANK(),
			    CALCULATE (
			        MAX ( State_ReleaseDates[ImplementationDate] ),
			        ALLSELECTED ( State_ReleaseDates )     -- respects BOTH States[State] and States[Cohort]
			    )
			)
		displayFolder: Date Helpers
		lineageTag: a39d62d1-471e-4b77-a13a-4bf313784e1b

	measure 'Has Selection' =
			
			OR ( ISFILTERED ( State_ReleaseDates[State] ), ISFILTERED ( State_ReleaseDates[Cohort] ) )
		formatString: """TRUE"";""TRUE"";""FALSE"""
		displayFolder: Date Helpers
		lineageTag: 34fd207a-af99-4d5b-a854-245e15c29fa2

	measure 'State Start Date' =
			
			VAR _state = SELECTEDVALUE('State_ReleaseDates'[State])
			RETURN
			IF(
			    ISBLANK(_state),
			    BLANK(),
			    CALCULATE(
			        MAX('State_ReleaseDates'[ImplementationDate]),
			        KEEPFILTERS('State_ReleaseDates'[State] = _state)
			    )
			)
		formatString: General Date
		displayFolder: Date Helpers
		lineageTag: ab623536-4f93-4c1f-9976-a87c95539669

	measure Implementation_PrevYear_WindowStart =
			
			VAR s = [Implementation_WindowStart]
			RETURN IF(ISBLANK(s), BLANK(), EDATE(s, -12))
		formatString: General Date
		displayFolder: Date Helpers
		lineageTag: bd59fe3a-b52b-48cf-b7ca-0da9d72070fe

	measure Implementation_PrevYear_WindowEnd =
			
			VAR e = [Implementation_WindowEnd]
			RETURN IF(ISBLANK(e), BLANK(), EDATE(e, -12))
		formatString: General Date
		displayFolder: Date Helpers
		lineageTag: d6098cf4-aa8f-4f37-b32b-b5e37f4576d5

	measure Issued_Implementation_to_Current =
			
			VAR s = [Implementation_WindowStart]
			VAR e = [Implementation_WindowEnd]
			RETURN
			IF (
			    ISBLANK ( s ) || ISBLANK ( e ),
			    BLANK(),
			    CALCULATE (
			        [Issued],
			        FILTER (
			            ALL ( wc_carrier_placement_snapshot[policy_sub_dt] ),   -- clear date to aggregate the entire window
			            wc_carrier_placement_snapshot[policy_sub_dt] >= s &&
			            wc_carrier_placement_snapshot[policy_sub_dt] <= e
			        )
			    )
			)
		formatString: #,0
		displayFolder: Measures (Time Period Specific)\Counts
		lineageTag: 0cfdefcd-dd6a-48c2-a24c-24f1db87c40c

