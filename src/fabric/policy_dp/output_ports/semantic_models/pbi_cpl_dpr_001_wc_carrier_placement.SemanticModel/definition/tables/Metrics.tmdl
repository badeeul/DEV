	measure UniqueMatch_Count =
			
			CALCULATE(
			    COUNT(wc_carrier_placement_snapshot[policy_num_bus_key]),
			        FILTER(wc_carrier_placement_snapshot, wc_carrier_placement_snapshot[all_category_points_match_flag]="Y")
			)
