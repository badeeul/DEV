		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Points Validation
		lineageTag: d212b303-dc27-4cf4-bbd3-166eacc1a47a

	measure 'Dynamic Chart Title' =
			
			VAR Metric =
			    SELECTEDVALUE('Point Category'[Metric], "Total")
			
			-- counts
			VAR StateCount =
			    COUNTROWS(VALUES('State_ReleaseDates'[State]))
			
			VAR TotalStates =
			    COUNTROWS(ALL('State_ReleaseDates'[State]))
			
			VAR CohortCount =
			    COUNTROWS(VALUES('State_ReleaseDates'[Cohort]))
			
			VAR TotalCohorts =
			    COUNTROWS(ALL('State_ReleaseDates'[Cohort]))
			
			-- 🔑 Detect if selection is purely cohort-based
			VAR SelectedStates =
			    VALUES('State_ReleaseDates'[State])
			
			VAR FullCohortSelection =
			    CALCULATE(
			        COUNTROWS('State_ReleaseDates'),
			        ALLSELECTED('State_ReleaseDates')
			    )
			    =
			    CALCULATE(
			        COUNTROWS('State_ReleaseDates'),
			        ALL('State_ReleaseDates'[State])
			    )
			
			-- text
			VAR StateText =
			    CONCATENATEX(
			        SelectedStates,
			        'State_ReleaseDates'[State],
			        ", "
			    )
			
			VAR CohortText =
			    CONCATENATEX(
			        VALUES('State_ReleaseDates'[Cohort]),
			        'State_ReleaseDates'[Cohort],
			        ", "
			    )
			
			RETURN
			"Points Distribution - " & Metric &
			SWITCH(
			    TRUE(),
			
			    -- ✅ ONLY if selection corresponds exactly to full cohorts
			    FullCohortSelection && CohortCount <> TotalCohorts,
			        ": " & CohortText,
			
			    -- ✅ Otherwise show states
			    StateCount <> TotalStates,
			        ": " & StateText,
			
			    ""
			)
		lineageTag: 24fc34b7-ebf5-4d2f-a997-92f4becc1438

