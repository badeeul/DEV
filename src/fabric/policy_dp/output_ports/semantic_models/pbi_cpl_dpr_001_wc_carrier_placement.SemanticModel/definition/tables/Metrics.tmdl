table Metrics
	lineageTag: 7446061c-593e-4256-be18-871fb9193f8a

	measure Issued =
			
			CALCULATE(SUM(wc_carrier_placement_snapshot[Policy_Issued])) + 0
		formatString: #,0
		displayFolder: Measures (Not Time Period Specific)\Counts
		lineageTag: 3a25753a-923c-4548-91c8-e009fcf1446a

	measure Quoted =
			
			CALCULATE(SUM(wc_carrier_placement_snapshot[Policy_Quoted])) + 0
		formatString: #,0
		displayFolder: Measures (Not Time Period Specific)\Counts
		lineageTag: f3741b77-71e8-4ee1-b899-442ef58b30a6

	measure Submitted =
			
