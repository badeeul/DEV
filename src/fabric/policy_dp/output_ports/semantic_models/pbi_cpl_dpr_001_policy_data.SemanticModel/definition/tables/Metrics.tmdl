	measure 'Applicable to Digital Decisioning' =
			
			VAR DatesInScope =
			    FILTER (
			        VALUES ( 'Date'[Date] ),
			        [Is Date In Scope] = 1
			    )
			
			RETURN
			CALCULATE(
			    SUM ( 'Policy Measures'[NB Submitted Count] ) + 0,
			    FILTER (
			        'Digital Decision Status',
			        'Digital Decision Status'[dd_l0_level]
			            IN {
			                "Completed Digital Decisioned Journey",
			                "Incomplete"
			            }
			    ),
			        TREATAS (
			        DatesInScope,
			        'Policy Effective Start Date'[Date]
			    )
			)
		formatString: #,0
		displayFolder: Policy Measures\Digital Decisioning\Counts
		lineageTag: 1f7cbce8-dfb1-40f7-921c-72edd0bc92a3

