	measure 'NB Efficiencies Metric Label' = ```
			
			VAR MetricName =
			    MAX ( 'NB Efficiencies Y-Axis Metric'[NB Efficiencies Y-Axis Metric] )
			RETURN
			SWITCH (
			    MetricName,
			    "Submitted Count",       "Submitted Count",
			    "Submitted Premium",     "Submitted Premium",
			    "Submitted Count"
