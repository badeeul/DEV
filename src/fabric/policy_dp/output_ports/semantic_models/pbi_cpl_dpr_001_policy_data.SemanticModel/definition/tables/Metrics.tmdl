/// Container table to organize measures (no data).
table Metrics
	lineageTag: bf4fdee2-015a-4e35-933f-756afa62f3d6

	/// Commission amount
	measure 'Commission Amount' = SUM('Policy Transactions'[Commission Amount])
		formatString: \$#,0;(\$#,0);\$#,0
		isHidden
		displayFolder: Policy Transactions\Commission
		lineageTag: f3166495-8c1b-4486-99bf-a33eb4d45a71

		changedProperty = Name

		changedProperty = Description

		changedProperty = DisplayFolder

		changedProperty = FormatString

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Data As Of Date' = MAX(Policy[dl_row_insert_timestamp]) - 1
		formatString: mm/dd/yyyy
		displayFolder: For Report Displays\Report Dates
		lineageTag: aad38175-926d-4219-b3b5-6ec93659416c

		annotation PBI_FormatHint = {"isCustom":true}

	/// New business hit ratio. Calculated as:
	/// new business total issued count / new business total quoted count
	measure 'NB Hit Ratio' = DIVIDE([NB Issued Count], [NB Quoted Count])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Policy Measures\Ratios
		lineageTag: b5330c72-7815-4af3-b63d-71dc9b13a300

		changedProperty = Name

		changedProperty = Description

		changedProperty = DisplayFolder

		changedProperty = FormatString

	/// New Business Issued Count
	measure 'NB Issued Count' =
			
			CALCULATE (
			    SUM ( 'Policy Measures'[NB Issued Count] ),
			
			    KEEPFILTERS(
			        FILTER(
			            VALUES('Date'[Date]),
			            [Is Date In Scope] = 1
			            )
			    ),
			
			    REMOVEFILTERS ( 'Policy Effective Start Date' ),
			    REMOVEFILTERS ( 'Policy Submission Date' )
			)
		formatString: #,0
		displayFolder: Policy Measures\Counts
		lineageTag: fc362f92-e14c-4cca-a0e3-da55d0bde8b8

		changedProperty = Name

		changedProperty = Description

		changedProperty = DisplayFolder

		changedProperty = FormatString

	/// New business quote ratio. Calculated as:
