	measure 'Is Date In Scope' =
			
			VAR SelectedPeriod =
			    SELECTEDVALUE ( 'Report Date Periods'[Period Key], "DEFAULT" )
			
			VAR IsDefaultPeriod =
			    SelectedPeriod = "DEFAULT"
			
			VAR AsOfDate =
			    [Data As Of Date]
			
			-- First day of the month represented by the row
			VAR MonthStartDate =
			    MIN ( 'Date'[date] )
			
			VAR IsPriorYear =
			    MAX ( 'Date'[Prior Year] ) = 1
			
			VAR IsCurrentYearUpToAsOfMonth =
			    YEAR ( MonthStartDate ) = YEAR ( AsOfDate )
			        && MonthStartDate <= AsOfDate
			
			RETURN
			SWITCH (
			    TRUE(),
			
			    -- Default: all 2025 + 2026 through As‑Of month
			    IsDefaultPeriod
			        && ( IsPriorYear || IsCurrentYearUpToAsOfMonth ),
			        1,
			
			    -- Custom: allow everything
			    NOT IsDefaultPeriod,
			        1,
			
			    0
			)
		formatString: 0
		displayFolder: For Report Displays\Report Dates
		lineageTag: c417a466-31f7-4996-a9b6-7e63754aa3b6

		changedProperty = Name

	measure 'Report Date Range' =
			
			VAR SelectedPeriod =
			    SELECTEDVALUE ( 'Report Date Periods'[Period Key], "DEFAULT" )
			
			VAR StartDate =
			    IF (
			        SelectedPeriod = "DEFAULT",
			        DATE ( YEAR ( [Data As Of Date] ) - 1, 1, 1 ),
			        MIN ( 'Date'[date] )
			    )
			
			VAR EndDate =
			    IF (
			        SelectedPeriod = "DEFAULT",
			        [Data As Of Date],
			        MAX ( 'Date'[date] )
			    )
			
			RETURN
			"Showing results from "
			    & FORMAT ( StartDate, "M/d/yyyy" )
			    & " to "
			    & FORMAT ( EndDate, "M/d/yyyy" )
		displayFolder: For Report Displays\Report Dates
		lineageTag: d5b7e50f-ee83-47f3-8994-dfc4e4612709

	measure 'Average NB Issued Premium' =
			
			CALCULATE (
			    AVERAGEX (
			        'Policy Measures',
			        'Policy Measures'[NB Issued Premium]
			    ),
			
			    -- Only rows where a policy was issued
			    'Policy Measures'[NB Issued Count] = 1,
			
			    -- Important: remove role-playing date interference
			    REMOVEFILTERS ( 'Policy Effective Start Date' ),
			    REMOVEFILTERS ( 'Policy Submission Date' )
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Policy Measures\Premium
		lineageTag: f6846970-6bcf-454f-972d-b71dd6932e4a

		changedProperty = Name

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

